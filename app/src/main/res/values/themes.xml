<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ShareIt" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">#1565C0</item>
        <item name="android:navigationBarColor">#0D47A1</item>
    </style>

    <style name="Theme.ShareIt.Surprise" parent="android:Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
